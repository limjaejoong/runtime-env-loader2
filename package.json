{
  "name": "runtime-env-loader",
  "version": "0.1.0",
  "description": "Load env from AWS Secrets Manager/local file and expose safe public config",
  "main": "src/index.js",
  "browser": "src/browser.js",
  "type": "commonjs",
  "exports": {
    ".": {
      "browser": "./src/browser.js",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "test": "node test/runtime-env-loader.test.js",
    "sample:server:dev": "APP_ENV=dev node sample/run-server.js",
    "sample:server:sqa": "APP_ENV=sqa node sample/run-server.js",
    "sample:server_browser:dev": "APP_ENV=dev node sample/run-server_browser.js",
    "sample:server_browser:sqa": "APP_ENV=sqa node sample/run-server_browser.js",
    "sample:serverless_browser:dev": "APP_ENV=dev node sample/run-serverless_browser.js",
    "sample:serverless_browser:sqa": "APP_ENV=sqa node sample/run-serverless_browser.js"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.867.0"
  }
}
