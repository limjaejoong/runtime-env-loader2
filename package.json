{
  "name": "secrets-env-loader",
  "version": "0.1.0",
  "description": "Load env from AWS Secrets Manager/local file and expose safe public config",
  "main": "src/index.js",
  "browser": "src/browser.js",
  "type": "commonjs",
  "exports": {
    ".": {
      "browser": "./src/browser.js",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "test": "echo \"No tests configured\"",
    "sample": "node sample/run-backend.js",
    "sample:dev": "APP_ENV=dev node sample/run-backend.js",
    "sample:sqa": "APP_ENV=sqa node sample/run-backend.js",
    "sample:uat": "APP_ENV=uat node sample/run-backend.js",
    "sample:prod": "APP_ENV=prod node sample/run-backend.js",
    "sample:frontend": "APP_ENV=dev node sample/run-frontend.js",
    "sample:frontend:dev": "APP_ENV=dev node sample/run-frontend.js",
    "sample:frontend:sqa": "APP_ENV=sqa node sample/run-frontend.js",
    "sample:frontend:uat": "APP_ENV=uat node sample/run-frontend.js",
    "sample:frontend:prod": "APP_ENV=prod node sample/run-frontend.js"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.867.0"
  },
  "license": "MIT"
}
